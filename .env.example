# === Convex (dashboard backend: telemetry cache, run snapshots) ===
# Set after running: npx convex dev  (creates .env.local with NEXT_PUBLIC_CONVEX_URL)
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# === Snapshot upload (optional) ===
# When set, demo scripts POST run snapshots to the dashboard for topology view.
# Example: DASHBOARD_URL=http://localhost:3000  (start dashboard with npm run dashboard first)
# DASHBOARD_URL=

# === LLM Provider ===
# Leave LLM_API_KEY empty for offline demos (simulated LLM). Set for real API (OpenAI, OpenRouter, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=

# === Models (OpenRouter or OpenAI format) ===
MODEL_FAST=anthropic/claude-haiku-4.5
MODEL_BALANCED=anthropic/claude-sonnet-4.5
MODEL_POWERFUL=anthropic/claude-opus-4.6

# === Embeddings ===
# USE_LOCAL_EMBEDDINGS=true → TF-IDF (no API key). false → use EMBEDDING_API_* below.
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=128

# === Celo — Telemetry (used by demos and RootRouter at runtime) ===
# Set these to log telemetry on-chain. Use Alfajores or Mainnet RPC + your wallet + contract address.
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_PRIVATE_KEY=
TELEMETRY_CONTRACT_ADDRESS=

# === Celo — Mainnet (for deploy script only: npm run deploy:contract) ===
# When set, deploy script uses mainnet. Fill after deploying; then set TELEMETRY_CONTRACT_ADDRESS above to the same value for demos.
CELO_RPC_URL_MAINNET=https://forno.celo.org
CELO_PRIVATE_KEY_MAINNET=
TELEMETRY_CONTRACT_ADDRESS_MAINNET=

# === RootRouter Config ===
CHAMBER_COUNT=8
REFIT_INTERVAL=20
MAX_CONTEXT_TOKENS=4096
EASY_NORM_THRESHOLD=0.3
MEDIUM_NORM_THRESHOLD=0.6
MIN_INTERACTIONS_BEFORE_FIT=15
PCA_DIMENSIONS=8

# === Optional ===
VERBOSE=false

# Lighter demos (fewer LLM calls): set DEMO_QUICK=true
# basic: 15 instead of 40, benchmark: 15 instead of 50, swarm: 21 instead of 60
# DEMO_QUICK=true

# For cheap real-LLM runs, use one model for all tiers (e.g. gpt-4o-mini):
# MODEL_FAST=gpt-4o-mini
# MODEL_BALANCED=gpt-4o-mini
# MODEL_POWERFUL=gpt-4o-mini
