# === LLM Provider ===
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-key-here

# === Models (OpenRouter format) ===
MODEL_FAST=anthropic/claude-haiku-4.5
MODEL_BALANCED=anthropic/claude-sonnet-4.5
MODEL_POWERFUL=anthropic/claude-opus-4.6

# === Embeddings ===
# Set USE_LOCAL_EMBEDDINGS=true to use TF-IDF (no API needed)
USE_LOCAL_EMBEDDINGS=true
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=your-openai-key-here
EMBEDDING_DIMENSION=128

# === Celo (Alfajores Testnet) ===
CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_PRIVATE_KEY=your-testnet-private-key
TELEMETRY_CONTRACT_ADDRESS=

# === RootRouter Config ===
CHAMBER_COUNT=8
REFIT_INTERVAL=20
MAX_CONTEXT_TOKENS=4096
EASY_NORM_THRESHOLD=0.3
MEDIUM_NORM_THRESHOLD=0.6
MIN_INTERACTIONS_BEFORE_FIT=15
PCA_DIMENSIONS=8
